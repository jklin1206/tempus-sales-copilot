    "@types/react-dom": "^19.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.5.4",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
