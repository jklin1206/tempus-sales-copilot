# Copy to .env and fill in. The key is server-side only.
#
# Never rename this to NEXT_PUBLIC_*, or the key ships to the browser.
# The app runs with NO key at all: it enters demo mode and serves a bundled, validated
# brief, so a reviewer can exercise the whole workflow without credentials. Demo mode is
# entered by not setting a key and by nothing else. It is never fallen into because a live
# generation failed. See src/lib/mode.ts.

GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_MODEL=gemini-3.1-flash-lite
